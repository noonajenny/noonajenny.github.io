<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🐻 Boekoe Tjap Haetjhan</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Baloo+2:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --red:          #C8312A;
  --red-dark:     #8B1A14;
  --red-deeper:   #5C0E0A;
  --red-light:    #F5E0DC;
  --red-border:   #C07060;
  --cream:        #F2EAC8;
  --cream-dark:   #C8A84A;
  --cream-light:  #FBF7E8;
  --brown:        #3D1F0A;
  --brown-mid:    #6B3318;
  --brown-light:  #F0E4D0;
  --green:        #2E4A2E;
  --green-mid:    #3D6B3D;
  --green-light:  #D8EAD8;
  --espresso:     #2A1008;
  --muted:        #6B3A20;
  --white:        #FBF7E8;

  /* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
     BACKGROUND PHOTO — ganti URL di bawah ini
     dengan URL foto yang lo mau jadiin background.
     Contoh: url('https://i.imgur.com/xxxxx.jpg')
     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
  --bg-photo: none;
}

html, body {
  min-height: 100vh;
  font-family: 'Fredoka', sans-serif;
  color: var(--espresso);
}

body {
  /* Photo background layer — will show when --bg-photo is set */
  background-color: #2A4A2A;
  background-image: var(--bg-photo);
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  /* Fallback noise texture so it doesn't look empty without photo */
}
body::before {
  content: '';
  position: fixed; inset: 0;
  /* Dark overlay so card reads clearly over any photo */
  background: rgba(20, 35, 18, 0.72);
  z-index: 0;
  pointer-events: none;
}

.container {
  max-width: 480px;
  margin: 0 auto;
  padding: 1.5rem 1rem 5rem;
  position: relative;
  z-index: 1;
}

/* ── HEADER ── */
.header {
  background: url('data:image/png;base64,') center/cover no-repeat;
  border-radius: 18px 18px 0 0;
  padding: 1.5rem 1.5rem 1.3rem;
  position: relative;
  overflow: hidden;
  border: 2.5px solid var(--red-dark);
  border-bottom: none;
  box-shadow: 0 8px 36px rgba(0,0,0,0.5);
}
.header::before {
  content: '';
  position: absolute; inset: 0;
  background: repeating-linear-gradient(-45deg, transparent, transparent 10px, rgba(0,0,0,0.035) 10px, rgba(0,0,0,0.035) 11px);
  pointer-events: none;
}
.header-nation {
  font-family: 'Fredoka', sans-serif;
  font-size: 12px; font-weight: 600;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--cream); margin-bottom: 5px; opacity: 0.85;
}
.header-title {
  font-family: 'Baloo 2', sans-serif;
  font-size: 23px; font-weight: 800;
  color: var(--cream); line-height: 1.15;
  text-shadow: 1px 2px 0 rgba(0,0,0,0.3);
}
.header-sub {
  font-size: 12px; font-weight: 600;
  color: rgba(242,234,200,0.65);
  letter-spacing: 2px; margin-top: 5px; text-transform: uppercase;
}
.header-badge {
  display: inline-block;
  background: var(--cream);
  border: 2px solid var(--cream-dark);
  border-radius: 6px;
  padding: 4px 14px;
  font-family: 'Baloo 2', sans-serif;
  font-size: 15px; font-weight: 800;
  color: var(--red-dark); margin-top: 10px; letter-spacing: 1px;
}
.header-twitter {
  font-size: 13px; font-weight: 500;
  color: rgba(242,234,200,0.72); margin-top: 4px; min-height: 20px;
}
.header-emblem {
  position: absolute; right: 0.6rem; top: 50%;
  transform: translateY(-50%);
  width: 115px; height: 115px;
  border: none; border-radius: 0;
  background: transparent;
  z-index: 1;
}

/* ── TABS ── */
.tabs {
  display: flex;
  background: var(--brown-light);
  border-left: 2.5px solid var(--red-dark);
  border-right: 2.5px solid var(--red-dark);
  border-bottom: 1px solid #C8A070;
}
.tab-btn {
  flex: 1; padding: 11px 6px;
  font-family: 'Fredoka', sans-serif;
  font-size: 14px; font-weight: 600; letter-spacing: 0.3px;
  background: none; border: none; cursor: pointer;
  color: var(--brown-mid);
  border-bottom: 3.5px solid transparent;
  transition: all 0.18s;
}
.tab-btn.active { color: var(--red-dark); border-bottom-color: var(--red); font-weight: 700; }
.tab-btn:hover:not(.active) { color: var(--red); }

/* ── CARD WRAPPER ── */
.card {
  background: var(--cream-light);
  border: 2.5px solid var(--red-dark);
  border-top: none;
  border-radius: 0 0 18px 18px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.45);
  overflow: hidden;
}
.panel { display: none; padding: 1.4rem; }
.panel.active { display: block; }

/* ── IDENTITY BOX ── */
.identity-box {
  background: var(--red);
  border-radius: 12px;
  padding: 1.1rem 1.25rem;
  margin-bottom: 1.25rem;
  border: 1.5px solid var(--red-dark);
}
.identity-title {
  font-family: 'Baloo 2', sans-serif;
  font-size: 11px; font-weight: 800;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--cream); margin-bottom: 10px; opacity: 0.8;
}
.identity-row { display: flex; gap: 8px; align-items: center; margin-bottom: 10px; }
.id-prefix {
  font-family: 'Baloo 2', sans-serif;
  font-size: 18px; font-weight: 800;
  color: var(--cream); flex-shrink: 0;
}
.id-input {
  flex: 1; padding: 10px 13px;
  border-radius: 8px;
  border: 1.5px solid rgba(242,234,200,0.35);
  background: rgba(0,0,0,0.22);
  color: var(--cream);
  font-family: 'Fredoka', sans-serif;
  font-size: 16px; font-weight: 500;
  outline: none; transition: border-color 0.15s;
}
.id-input:focus { border-color: rgba(242,234,200,0.7); }
.id-input::placeholder { color: rgba(242,234,200,0.38); }

.kode-sublabel {
  font-family: 'Baloo 2', sans-serif;
  font-size: 10px; font-weight: 800;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--cream); opacity: 0.72; margin-bottom: 6px;
}
.kode-row { display: flex; gap: 8px; align-items: center; }
.kode-disp {
  flex: 1;
  background: var(--cream);
  border: 2px solid var(--cream-dark);
  border-radius: 8px;
  padding: 10px 14px;
  font-family: 'Baloo 2', sans-serif;
  font-size: 19px; font-weight: 800;
  color: var(--red-dark); letter-spacing: 2px; text-align: center;
  user-select: all;
}
.btn-icon {
  padding: 10px 13px;
  background: var(--cream); color: var(--red-dark);
  border: 2px solid var(--cream-dark);
  border-radius: 8px; font-size: 17px;
  cursor: pointer; transition: all 0.15s; flex-shrink: 0;
}
.btn-icon:hover { background: var(--cream-dark); color: #fff; }

.id-hint {
  font-size: 12px; font-weight: 500;
  color: rgba(242,234,200,0.6); margin-top: 9px; line-height: 1.55;
}
.divider-red { border: none; border-top: 1px solid rgba(242,234,200,0.2); margin: 11px 0; }

.restore-label {
  font-family: 'Fredoka', sans-serif;
  font-size: 13px; font-weight: 500;
  color: rgba(242,234,200,0.58); margin-bottom: 7px;
}
.restore-row { display: flex; gap: 8px; align-items: center; }
.restore-input {
  flex: 1; padding: 9px 12px;
  border-radius: 8px;
  border: 1.5px solid rgba(242,234,200,0.3);
  background: rgba(0,0,0,0.2);
  color: var(--cream);
  font-family: 'Baloo 2', sans-serif;
  font-size: 14px; font-weight: 700; letter-spacing: 1px;
  outline: none; transition: border-color 0.15s;
}
.restore-input:focus { border-color: rgba(242,234,200,0.65); }
.restore-input::placeholder { font-weight: 500; letter-spacing: 0; color: rgba(242,234,200,0.35); }
.btn-sm {
  padding: 9px 15px;
  background: var(--cream); color: var(--red-dark);
  border: 2px solid var(--cream-dark);
  border-radius: 8px;
  font-family: 'Fredoka', sans-serif;
  font-size: 14px; font-weight: 600;
  cursor: pointer; white-space: nowrap; transition: all 0.15s;
}
.btn-sm:hover { background: var(--cream-dark); color: #fff; }

/* ── SECTION LABEL ── */
.sec-label {
  font-family: 'Baloo 2', sans-serif;
  font-size: 11px; font-weight: 800;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--brown-mid); margin-bottom: 11px;
}

/* ── EVENT CARDS ── */
.event-card {
  border: 1.5px solid #C8A070;
  border-radius: 12px; padding: 0.95rem 1.05rem;
  margin-bottom: 9px;
  display: flex; align-items: flex-start; gap: 12px;
  background: var(--white); cursor: pointer; transition: all 0.15s;
}
.event-card:hover { border-color: var(--red); background: #FFF5EE; }
.event-card.selected { border-color: var(--red); border-width: 2px; background: var(--red-light); }
.event-card.done { opacity: 0.5; cursor: default; }

.ev-icon {
  width: 46px; height: 46px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 23px; flex-shrink: 0;
  background: var(--brown-light);
  border: 1px solid #C8A070;
}
.ev-info { flex: 1; min-width: 0; }
.ev-name  {
  font-family: 'Baloo 2', sans-serif;
  font-size: 14px; font-weight: 700;
  color: var(--espresso); line-height: 1.25;
}
.ev-venue {
  font-family: 'Fredoka', sans-serif;
  font-size: 13px; font-weight: 600;
  color: var(--red-dark); margin-top: 2px;
}
.ev-date  {
  font-family: 'Fredoka', sans-serif;
  font-size: 12px; color: var(--muted); margin-top: 2px;
}
.ev-badge {
  flex-shrink: 0; font-family: 'Fredoka', sans-serif;
  font-size: 12px; font-weight: 600;
  padding: 4px 10px; border-radius: 6px; margin-top: 3px; white-space: nowrap;
}
.badge-done    { background: var(--cream); color: var(--red-dark); border: 1.5px solid var(--cream-dark); }
.badge-pending { background: #FFF8E1; color: #7A4800; border: 1.5px solid #F0C040; }

/* ── CHECKIN BOX ── */
.checkin-box {
  background: var(--brown-light);
  border: 1.5px solid #C8A070;
  border-radius: 14px; padding: 1.25rem; margin-top: 10px;
  animation: slideDown 0.2s ease;
}
@keyframes slideDown { from { opacity:0; transform:translateY(-8px); } to { opacity:1; transform:translateY(0); } }

.upload-area {
  border: 2px dashed #C8A070;
  border-radius: 11px; padding: 1.6rem 1rem;
  text-align: center; cursor: pointer;
  background: var(--white); transition: all 0.15s;
}
.upload-area:hover { border-color: var(--red); background: #FFF8F4; }
.upload-area.has-file { border-color: var(--green); border-style: solid; }
.upload-icon-big { font-size: 38px; display: block; margin-bottom: 8px; }
.upload-txt  {
  font-family: 'Baloo 2', sans-serif;
  font-size: 15px; font-weight: 700; color: var(--brown);
}
.upload-hint { font-size: 13px; color: var(--muted); margin-top: 4px; }
input[type="file"] { display: none; }

.compress-note {
  display: none; align-items: center; gap: 7px;
  background: var(--green-light);
  border: 1.5px solid var(--green-mid);
  border-radius: 8px; padding: 8px 12px; margin-top: 9px;
  font-family: 'Fredoka', sans-serif; font-size: 13px; font-weight: 600; color: var(--green);
}
.admin-note {
  background: var(--white);
  border-left: 3px solid var(--red);
  border-radius: 0 9px 9px 0;
  padding: 10px 13px; margin-top: 11px;
  font-family: 'Fredoka', sans-serif; font-size: 13px; font-weight: 500; color: var(--muted);
}
.btn-tjap {
  width: 100%; padding: 14px;
  background: var(--red); color: var(--cream); border: none;
  border-radius: 11px;
  font-family: 'Baloo 2', sans-serif;
  font-size: 16px; font-weight: 800;
  letter-spacing: 2px; text-transform: uppercase;
  cursor: pointer; margin-top: 13px; transition: all 0.2s;
  border-bottom: 4px solid var(--red-dark);
}
.btn-tjap:not(:disabled):hover { background: var(--red-dark); transform: translateY(-1px); }
.btn-tjap:not(:disabled):active { transform: translateY(1px); border-bottom-width: 1px; }
.btn-tjap:disabled { opacity: 0.35; cursor: not-allowed; }

.compressing { display:none; text-align:center; padding:1rem; color:var(--muted); font-family:'Fredoka',sans-serif; font-size:14px; font-weight:500; }
.compressing.show { display:block; }
.spin { display:inline-block; animation:spin 1s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

/* ── SUCCESS ── */
.tjap-success { display:none; text-align:center; padding:1.5rem 1rem; }
.tjap-success.show { display:block; animation:popIn 0.5s cubic-bezier(0.34,1.56,0.64,1); }
@keyframes popIn { from{transform:scale(0.5);opacity:0;} to{transform:scale(1);opacity:1;} }

.tjap-circle {
  width: 140px; height: 140px; border-radius: 50%;
  border: 5px solid; margin: 0 auto 1.1rem;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center; position: relative;
}
.tjap-circle::before {
  content:''; position:absolute; inset:7px;
  border-radius:50%; border:1.5px dashed; border-color:inherit; opacity:0.35;
}
.tjap-big-icon    { font-size: 32px; }
.tjap-circle-name { font-family:'Baloo 2',sans-serif; font-size:12px; font-weight:800; text-align:center; line-height:1.2; margin-top:4px; }
.tjap-circle-date { font-family:'Fredoka',sans-serif; font-size:11px; margin-top:3px; }
.success-heading  { font-family:'Baloo 2',sans-serif; font-size:24px; font-weight:800; color:var(--red-dark); margin-bottom:7px; }
.success-body     { font-size:14px; color:var(--muted); margin-bottom:1.4rem; line-height:1.55; font-family:'Fredoka',sans-serif; }
.btn-outline {
  padding:11px 24px;
  background:var(--cream-light); color:var(--red-dark);
  border:2px solid #C8A070;
  border-radius:9px;
  font-family:'Fredoka',sans-serif; font-size:15px; font-weight:600;
  cursor:pointer; transition:all 0.15s;
}
.btn-outline:hover { border-color:var(--red); background:var(--red-light); }

/* ── KOLEKSI ── */
.stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:9px; margin-bottom:1.1rem; }
.stat-card {
  background:var(--red); border:2px solid var(--red-dark);
  border-radius:11px; padding:13px 8px; text-align:center;
}
.stat-num { font-family:'Baloo 2',sans-serif; font-size:30px; font-weight:800; color:var(--cream); }
.stat-lbl { font-family:'Fredoka',sans-serif; font-size:12px; font-weight:600; color:rgba(242,234,200,0.72); letter-spacing:0.5px; text-transform:uppercase; margin-top:1px; }

.prog-wrap { margin-bottom:1.1rem; }
.prog-meta { font-family:'Fredoka',sans-serif; font-size:13px; font-weight:600; color:var(--brown-mid); display:flex; justify-content:space-between; margin-bottom:6px; }
.prog-bar  { height:10px; background:var(--red-light); border-radius:100px; overflow:hidden; border:1px solid var(--red-border); }
.prog-fill { height:100%; background:var(--red); border-radius:100px; transition:width 0.55s cubic-bezier(0.34,1.56,0.64,1); }

.passport-page {
  background: var(--red);
  border-radius: 14px; padding: 1.25rem;
  margin-bottom: 1.1rem; border: 2.5px solid var(--red-dark);
  position: relative; overflow: hidden;
}
.passport-page::before {
  content:'🐻'; position:absolute; right:-12px; bottom:-18px;
  font-size:95px; opacity:0.07; transform:rotate(-12deg); pointer-events:none;
}
.page-title { font-family:'Baloo 2',sans-serif; font-size:16px; font-weight:800; color:var(--cream); margin-bottom:1px; }
.page-sub   { font-family:'Fredoka',sans-serif; font-size:12px; font-weight:600; color:rgba(242,234,200,0.6); letter-spacing:1.5px; text-transform:uppercase; margin-bottom:1.1rem; }

.tjap-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }

/* wrapper: circle + label below */
.tjap-item { display:flex; flex-direction:column; align-items:center; gap:8px; }
.tjap-item-label {
  font-family:'Baloo 2',sans-serif; font-size:11px; font-weight:700;
  color:var(--cream); text-align:center; line-height:1.3;
  opacity:0.85; padding:0 4px;
}
.tjap-item-label.filled-label { opacity:1; color:var(--cream); }
.tjap-item-date {
  font-family:'Fredoka',sans-serif; font-size:10px; font-weight:500;
  color:rgba(242,234,200,0.6); text-align:center; margin-top:-4px;
}

.tjap-slot {
  width:100%; aspect-ratio:1;
  border:2px dashed rgba(242,234,200,0.3);
  border-radius:50%;
  display:flex; align-items:center; justify-content:center; flex-direction:column;
  background: rgba(242,234,200,0.12);
  opacity:0.55; font-family:'Fredoka',sans-serif;
  font-size:12px; font-weight:500; color:var(--cream);
  transition:all 0.25s; text-align:center; padding:0;
  overflow:hidden; position:relative;
}

/* filled = full image, no border visible */
.tjap-slot.filled {
  opacity:1; border:none; padding:0; cursor:pointer;
  background:transparent !important;
  box-shadow: 0 4px 16px rgba(0,0,0,0.35);
}
.tjap-slot.filled:hover { transform:scale(1.07) rotate(-2deg); box-shadow:0 6px 22px rgba(0,0,0,0.45); }
.tjap-slot.filled img {
  width:100%; height:100%;
  object-fit:cover; border-radius:50%;
  display:block;
}
/* pending = faded, dashed border, no full image */
.tjap-slot.pending {
  border:2px dashed rgba(242,234,200,0.5); opacity:0.6;
  padding:6px; background:rgba(0,0,0,0.15) !important;
}

.empty-state { text-align:center; padding:2rem 1rem; }
.empty-em  { font-size:44px; display:block; margin-bottom:11px; }
.empty-txt { font-family:'Baloo 2',sans-serif; font-size:17px; font-weight:700; color:var(--red-dark); line-height:1.45; }

/* ── INFO ── */
.info-step {
  border:1.5px solid #C8A070; border-radius:13px;
  padding:1rem 1.1rem; margin-bottom:9px;
  display:flex; align-items:flex-start; gap:12px;
  background:var(--white);
}
.step-no {
  width:38px; height:38px; border-radius:50%;
  background:var(--brown-light); display:flex; align-items:center; justify-content:center;
  font-family:'Baloo 2',sans-serif; font-size:18px; font-weight:800; color:var(--red); flex-shrink:0;
  border:1.5px solid #C8A070;
}
.step-t { font-family:'Baloo 2',sans-serif; font-weight:700; font-size:15px; color:var(--espresso); }
.step-d { font-size:13px; color:var(--muted); margin-top:3px; line-height:1.45; }

/* ── EVENT DETAIL CARDS ── */
.event-detail-card {
  background: var(--white);
  border: 1.5px solid #C8A070;
  border-radius: 12px;
  padding: 1rem 1.1rem;
  margin-bottom: 10px;
  display: flex; gap: 12px; align-items: flex-start;
}
.event-detail-icon {
  width: 42px; height: 42px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
  background: var(--brown-light); border: 1px solid #C8A070;
}
.event-detail-name {
  font-family: 'Baloo 2', sans-serif; font-size: 14px; font-weight: 800;
  color: var(--espresso); line-height: 1.2; margin-bottom: 3px;
}
.event-detail-venue {
  font-family: 'Fredoka', sans-serif; font-size: 13px; font-weight: 600;
  color: var(--red-dark);
}
.event-detail-date {
  font-family: 'Fredoka', sans-serif; font-size: 12px;
  color: var(--muted); margin-top: 2px;
}

/* ── ADMIN ── */
.admin-login-overlay { padding:2.5rem 1rem; text-align:center; }
.admin-login-title { font-family:'Baloo 2',sans-serif; font-size:20px; font-weight:800; color:var(--red-dark); margin-bottom:8px; }
.admin-login-sub   { font-size:14px; color:var(--muted); margin-bottom:1.3rem; font-family:'Fredoka',sans-serif; }
.admin-pw-input {
  display:block; width:100%; max-width:240px; margin:0 auto 12px;
  padding:11px 14px; border-radius:9px;
  border:2px solid #C8A070;
  background:var(--white);
  font-family:'Baloo 2',sans-serif; font-size:16px; font-weight:700;
  text-align:center; letter-spacing:3px; outline:none; color:var(--espresso);
}
.admin-pw-input:focus { border-color:var(--red); }
.btn-red {
  padding:11px 26px; background:var(--red); color:var(--cream);
  border:none; border-bottom:4px solid var(--red-dark);
  border-radius:9px;
