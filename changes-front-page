const PREFIX     = 'Haetjhan';
const ADMIN_PASS = 'haetjhan2026';
const ALL_KEY    = 'htj_all_users';
const MAX_BYTES  = 1 * 1024 * 1024;

const EVENTS = {
  kopi:      { name:'Kedai Kopi Haetjhan',   icon:'☕', color:'#8B1A14', bg:'#F5E0DC' },
  photo:     { name:'Bilik Potret Haetjhan', icon:'📸', color:'#2E4A2E', bg:'#D8EAD8' },
  videotron: { name:'Pariwara Haetjhan',     icon:'📺', color:'#5C3A10', bg:'#F5ECD8' },
  crazylove: { name:'Crzy Love Haechan',     icon:'🐻', color:'#8B1A14', bg:'#F5E0DC' }
};
const EV_IDS = Object.keys(EVENTS);

let myKode='', myTwitter='', myIG='', myTjap={};
let selEvent=null, photoOk=false, compressedBlob=null, adminIn=false;

// ── STORAGE ──────────────────────────────────────────────────
function allGet()    { try { return JSON.parse(localStorage.getItem(ALL_KEY)||'[]'); } catch { return []; } }
function allSet(arr) { localStorage.setItem(ALL_KEY, JSON.stringify(arr)); }
function upsert() {
  const arr=allGet(), i=arr.findIndex(u=>u.kode===myKode);
  const obj={kode:myKode,twitter:myTwitter,ig:myIG,tjap:myTjap,updated:Date.now()};
  if(i>=0) arr[i]=obj; else arr.push(obj);
  allSet(arr);
}
function persist() {
  localStorage.setItem('htj_kode', myKode);
  localStorage.setItem('htj_twitter_'+myKode, myTwitter);
  localStorage.setItem('htj_ig_'+myKode, myIG);
  localStorage.setItem('htj_tjap_'+myKode, JSON.stringify(myTjap));
  upsert();
}
function hydrate(kode) {
  myKode=kode;
  myTwitter=localStorage.getItem('htj_twitter_'+kode)||'';
  myIG=localStorage.getItem('htj_ig_'+kode)||'';
  const raw=localStorage.getItem('htj_tjap_'+kode);
  myTjap=raw?JSON.parse(raw):{};
  const found=allGet().find(u=>u.kode===kode);
  if(found){
    if(!myTwitter&&found.twitter) myTwitter=found.twitter;
    if(!myIG&&found.ig) myIG=found.ig;
    if(!Object.keys(myTjap).length&&found.tjap) myTjap=found.tjap;
  }
}

// ── INIT ─────────────────────────────────────────────────────
function genKode(){ return PREFIX+(Math.floor(Math.random()*900)+100); }
function init(){
  let k=localStorage.getItem('htj_kode')||genKode();
  hydrate(k);
  // populate main username input with whichever is set
  const mainInp=document.getElementById('main-username-input');
  if(mainInp){
    if(myTwitter){ idPlatform='x'; mainInp.value=myTwitter; document.getElementById('id-platform-btn').textContent='𝕏'; }
    else if(myIG){ idPlatform='ig'; mainInp.value=myIG; document.getElementById('id-platform-btn').textContent='📸'; }
  }
  persist(); refreshHeader(); refreshBadges();
  // Show onboarding if no username set yet
  if(!myTwitter&&!myIG){
    showOnboarding();
  } else {
    hideOnboarding();
  }
}

