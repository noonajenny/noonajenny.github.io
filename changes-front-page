// ── COMPRESSION ───────────────────────────────────────────────
function compressImage(file,maxBytes){
  return new Promise(resolve=>{
    const reader=new FileReader();
    reader.onload=e=>{
      const img=new Image();
      img.onload=()=>{
        const tryCompress=(quality,w,h)=>{
          const canvas=document.createElement('canvas');
          canvas.width=w; canvas.height=h;
          canvas.getContext('2d').drawImage(img,0,0,w,h);
          canvas.toBlob(blob=>{
            if(!blob){resolve(null);return;}
            if(blob.size<=maxBytes||quality<0.1){resolve(blob);}
            else if(quality>0.3){tryCompress(quality-0.1,w,h);}
            else{
              const scale=Math.sqrt(maxBytes/blob.size)*0.9;
              tryCompress(0.5,Math.floor(w*scale),Math.floor(h*scale));
            }
          },'image/jpeg',quality);
        };
        let w=img.width,h=img.height;
        if(w>1800){h=Math.floor(h*1800/w);w=1800;}
        tryCompress(0.85,w,h);
      };
      img.src=e.target.result;
    };
    reader.readAsDataURL(file);
  });
}
function fmtSize(b){return b>=1048576?(b/1048576).toFixed(2)+' MB':Math.round(b/1024)+' KB';}

async function handleFile(inp){
  if(!inp.files||!inp.files[0]) return;
  const file=inp.files[0];
  document.getElementById('up-icon').textContent='⏳';
  document.getElementById('up-txt').textContent='Memproses foto...';
  document.getElementById('compress-note').style.display='none';
  document.getElementById('compressing-indicator').classList.add('show');
  document.getElementById('btn-tjap').disabled=true;

  const blob=file.size<=MAX_BYTES?file:await compressImage(file,MAX_BYTES);
  document.getElementById('compressing-indicator').classList.remove('show');
  if(!blob){
    toast('Gagal memproses foto. Coba lagi.');
    document.getElementById('up-icon').textContent='❌';
    document.getElementById('up-txt').textContent='Gagal. Tap untuk coba lagi.';
    return;
  }
  compressedBlob=blob; photoOk=true;
  document.getElementById('up-icon').textContent='✅';
  document.getElementById('up-txt').textContent=file.name;
  document.getElementById('upload-area').classList.add('has-file');
  const note=document.getElementById('compress-note');
  document.getElementById('compress-size').textContent=
    fmtSize(blob.size)+(file.size>MAX_BYTES?' (dari '+fmtSize(file.size)+')':'');
  note.style.display='flex';
  document.getElementById('btn-tjap').disabled=false;
}

// ── DO TJAP ───────────────────────────────────────────────────
function lakukanTjap(){
  if(!selEvent||!photoOk) return;
  if(myTjap[selEvent]&&!myTjap[selEvent].pending){toast('Sudah ter-tjap!');return;}
  const ev=EVENTS[selEvent];
  const date=new Date().toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'});
  myTjap[selEvent]={date,pending:true};
  persist(); refreshBadges(); refreshHeader();
  document.getElementById('checkin-box').style.display='none';
  const c=document.getElementById('success-circle');
  c.style.borderColor=ev.color; c.style.background=ev.bg;
  c.innerHTML='<span class="tjap-big-icon">'+ev.icon+'</span>'+
    '<span class="tjap-circle-name" style="color:'+ev.color+'">'+ev.name+'</span>'+
    '<span class="tjap-circle-date" style="color:'+ev.color+'">'+date+'</span>';
  document.getElementById('success-body').textContent='Foto terkirim! Tjap aktif setelah diverifikasi admin. Cek lagi nanti ya 🐻';
  document.getElementById('tjap-success').style.display='block';
  setTimeout(()=>document.getElementById('tjap-success').classList.add('show'),10);
  toast('📷 Menunggu verifikasi admin');
}
function resetTjap(){
  document.querySelectorAll('.event-card').forEach(c=>c.classList.remove('selected'));
  selEvent=null; photoOk=false; compressedBlob=null;
  document.getElementById('checkin-box').style.display='none';
  document.getElementById('tjap-success').classList.remove('show');
  document.getElementById('tjap-success').style.display='none';
  document.getElementById('compress-note').style.display='none';
}

// ── KOLEKSI ───────────────────────────────────────────────────
function renderKoleksi(){
  const done=EV_IDS.filter(id=>myTjap[id]&&!myTjap[id].pending).length;
  const all=Object.keys(myTjap).length;
  document.getElementById('st-total').textContent=done;
  document.getElementById('st-pct').textContent=Math.round(done/4*100)+'%';
  document.getElementById('prog-fill').style.width=Math.round(done/4*100)+'%';
  document.getElementById('prog-lbl').textContent=done+' / 4';
  document.getElementById('empty-koleksi').style.display=all===0?'block':'none';
  EV_IDS.forEach(id=>{
    const slot=document.getElementById('slot-'+id);
    const lbl=document.getElementById('lbl-'+id);
    const dateEl=document.getElementById('date-'+id);
    const ev=EVENTS[id]; const t=myTjap[id];
    if(t){
      if(t.pending){
        // pending: krem polos, no icon
        slot.className='tjap-slot pending';
        slot.style.borderColor='rgba(242,234,200,0.5)';
        slot.style.background='rgba(242,234,200,0.18)';
        slot.innerHTML='';
        if(lbl){ lbl.className='tjap-item-label'; lbl.textContent=ev.name; }
        if(dateEl){ dateEl.textContent='⏳ Menunggu verifikasi'; }
      } else {
        // approved: full stamp image, no border, no internal text
        slot.className='tjap-slot filled';
        slot.style.borderColor='none'; slot.style.background='transparent';
        slot.innerHTML='<img src="data:image/png;base64," style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;"/>';
        if(lbl){ lbl.className='tjap-item-label filled-label'; lbl.textContent=ev.name; }
        if(dateEl){ dateEl.textContent='✅ '+t.date; }
      }
    } else {
      // empty: krem polos, no icon
      slot.className='tjap-slot'; 
      slot.style.borderColor='rgba(242,234,200,0.25)';
      slot.style.background='rgba(242,234,200,0.12)';
      slot.innerHTML='';
      if(lbl){ lbl.className='tjap-item-label'; lbl.textContent=ev.name; }
      if(dateEl){ dateEl.textContent=''; }
    }
  });
}

// ── ADMIN ─────────────────────────────────────────────────────
function adminLogin(){
  if(document.getElementById('admin-pw').value===ADMIN_PASS){
    adminIn=true;
    document.getElementById('admin-login-view').style.display='none';
    document.getElementById('admin-main-view').style.display='block';
    renderAdmin();
  } else { toast('Password salah! 🐻'); document.getElementById('admin-pw').value=''; }
}
function adminLogout(){
  adminIn=false;
  document.getElementById('admin-login-view').style.display='block';
  document.getElementById('admin-main-view').style.display='none';
  document.getElementById('admin-pw').value='';
}
function renderAdmin(){
  if(!adminIn) return;
  const users=allGet(); let totTjap=0,totPend=0;
  const tbP=document.getElementById('tbody-pending');
  tbP.innerHTML=''; let pc=0;
  users.forEach(u=>{
    EV_IDS.forEach(evId=>{
      const t=u.tjap&&u.tjap[evId];
      if(t&&t.pending){
        pc++; totPend++;
        const tr=document.createElement('tr');
        tr.innerHTML='<td><b>'+u.kode+'</b></td>'+
          '<td>'+(u.twitter?'@'+u.twitter:'—')+'</td>'+
          '<td>'+EVENTS[evId].icon+' '+EVENTS[evId].name+'</td>'+
          '<td><button class="btn-approve" onclick="approve(\''+u.kode+'\',\''+evId+'\')">✅ Setujui</button>'+
          '<button class="btn-del" onclick="reject(\''+u.kode+'\',\''+evId+'\')">✕</button></td>';
        tbP.appendChild(tr);
      }
    });
    if(u.tjap) totTjap+=EV_IDS.filter(id=>u.tjap[id]&&!u.tjap[id].pending).length;
  });
  document.getElementById('empty-pending').style.display=pc===0?'block':'none';
  const tbU=document.getElementById('tbody-users');
  tbU.innerHTML='';
  document.getElementById('empty-users').style.display=users.length===0?'block':'none';
  users.forEach(u=>{
    const done=u.tjap?EV_IDS.filter(id=>u.tjap[id]&&!u.tjap[id].pending).length:0;
    const pend=u.tjap?EV_IDS.filter(id=>u.tjap[id]&&u.tjap[id].pending).length:0;
    const detail=EV_IDS.map(id=>{
      const t=u.tjap&&u.tjap[id];
      if(!t) return '<span class="pill pill-none">'+EVENTS[id].icon+'</span>';
      return t.pending?'<span class="pill pill-pending">'+EVENTS[id].icon+' ⏳</span>'
        :'<span class="pill pill-done">'+EVENTS[id].icon+' ✅</span>';
    }).join(' ');
    const tr=document.createElement('tr');
    tr.innerHTML='<td><b>'+u.kode+'</b></td>'+
      '<td>'+(u.twitter?'@'+u.twitter:'—')+'</td>'+
      '<td><b>'+done+'</b>'+(pend>0?' <span style="color:#7A4800;font-size:12px">(+'+pend+' pending)</span>':'')+
      '</td><td>'+detail+'</td>';
    tbU.appendChild(tr);
  });
  document.getElementById('adm-users').textContent=users.length;
  document.getElementById('adm-tjap').textContent=totTjap;
  document.getElementById('adm-pending').textContent=totPend;
}
function approve(kode,evId){
  const arr=allGet(),u=arr.find(x=>x.kode===kode);
  if(!u||!u.tjap||!u.tjap[evId]) return;
  u.tjap[evId].pending=false; allSet(arr);
  localStorage.setItem('htj_tjap_'+kode,JSON.stringify(u.tjap));
  if(kode===myKode){myTjap[evId].pending=false;persist();refreshBadges();refreshHeader();}
  toast('✅ Tjap disetujui!'); renderAdmin();
}
function reject(kode,evId){
  if(!confirm('Tolak tjap ini?')) return;
  const arr=allGet(),u=arr.find(x=>x.kode===kode);
  if(!u||!u.tjap) return;
  delete u.tjap[evId]; allSet(arr);
  localStorage.setItem('htj_tjap_'+kode,JSON.stringify(u.tjap));
  if(kode===myKode){delete myTjap[evId];persist();refreshBadges();refreshHeader();}
  toast('Tjap ditolak'); renderAdmin();
}
function exportCSV(){
  const users=allGet();
  const rows=[['Kode','Twitter',...EV_IDS.map(id=>EVENTS[id].name)]];
  users.forEach(u=>{
    const row=[u.kode,u.twitter||''];
    EV_IDS.forEach(id=>{const t=u.tjap&&u.tjap[id];row.push(t?(t.pending?'pending':'done'):'');});
    rows.push(row);
  });
  const csv=rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download='haetjhan-peserta.csv';
  a.click();
}

function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}


// ── ONBOARDING ────────────────────────────────────────────────
function showOnboarding(){
  document.getElementById('onboarding-overlay').style.display='flex';
}
function hideOnboarding(){
  document.getElementById('onboarding-overlay').style.display='none';
}
function finishOnboarding(){
  const val=document.getElementById('ob-username').value.trim();
  if(!val){
    document.getElementById('ob-err').style.display='block';
    return;
  }
  document.getElementById('ob-err').style.display='none';
  if(obPlatform==='x'){ myTwitter=val; } else { myIG=val; }
  // sync main panel input
  idPlatform=obPlatform;
  const btn=document.getElementById('id-platform-btn');
  if(btn){ btn.textContent=idPlatform==='x'?'𝕏':'📸'; }
  const inp=document.getElementById('main-username-input');
  if(inp){ inp.value=val; }
  persist(); refreshHeader();
  hideOnboarding();
}

